      "authors": [
        {
          "name": "Boing Boing",
          "url": "https://boingboing.net/"
        }
      ],
      "image": "https://i0.wp.com/boingboing.net/wp-content/uploads/2026/07/Mercury_light_bulb-scaled.jpg?fit=2560%2C1920&quality=60&ssl=1",
      "_score": 36,
      "_quality": 55,
      "_relevance": 40,
      "_local_score": 0,
      "_content_type": "feature"
    },
